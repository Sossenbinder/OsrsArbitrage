# Site address comes from $DOMAIN (set in .env / compose):
#   • a real domain (arb.example.com) → Caddy obtains a free Let's Encrypt cert (HTTPS)
#   • a bare IP                       → Caddy serves plain HTTP (no ACME for IPs)
#   • unset                           → defaults to :80
{$DOMAIN} {
	encode zstd gzip

	# Blazor Server + SignalR ride on WebSockets; reverse_proxy upgrades them automatically.
	reverse_proxy app:8080

	log {
		output stdout
		format console
	}
}
