# Hardcoded site address → Caddy obtains a free Let's Encrypt cert automatically (HTTPS),
# and redirects HTTP→HTTPS. Change this line if the domain ever changes.
osrs-arbitrage.dotschranz.net {
	encode zstd gzip

	# Blazor Server + SignalR ride on WebSockets; reverse_proxy upgrades them automatically.
	reverse_proxy app:8080

	log {
		output stdout
		format console
	}
}
