@page "/"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using ArbitrageTracker.Web.Pipeline
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject SettingsStore Settings

<PageTitle>Arbitrage · OSRS GE</PageTitle>

<div class="dash">

    <header class="dash-head">
        <div class="brand">
            <span class="brand-mark">⚖</span>
            <div>
                <h1>Grand Exchange Arbitrage</h1>
                <p class="subtitle">
                    Live spreads from <strong>completed RuneLite trades</strong> via the OSRS Wiki.
                    Safety is a modeled <span class="tt"><span class="tt-trigger u">clean-fill probability</span><span class="tt-pop">The estimated chance you can buy <em>and</em> sell cleanly within the window. A risk estimate, not a guarantee — the displayed spread is never locked in.</span></span>, not a promise of profit.
                </p>
            </div>
        </div>
        <div class="status">
            <span class="pill @(IsLive ? "pill-live" : "pill-down")">
                <span class="dot"></span>@(IsLive ? "LIVE" : "STALE")
            </span>
            <span class="muted small">@FeedStatusText</span>
        </div>
    </header>

    @if (!IsLive)
    {
        <div class="alert">
            <strong>⛔ Data is not live right now.</strong>
            @FeedStatusText — prices on screen may be out of date. <strong>Do not place trades</strong> until this clears.
            @if (snap?.FeedError is { } err) { <span class="muted small">(@err)</span> }
        </div>
    }

    <details class="howto" open="@(!hasSeenHowto)">
        <summary>How to use this — read before you trade</summary>
        <ol>
            <li>This tool <strong>finds price gaps; it does not trade for you.</strong> You place every offer yourself in-game.</li>
            <li><strong>Set your bankroll</strong> in <a href="/settings">Settings</a> so the suggested quantities match the cash you actually have (currently sized for <strong>@Rationale.Gp(Settings.Sizing.Bankroll)</strong>).</li>
            <li>For a pick: place a <strong>BUY offer at the Buy price</strong> for the suggested quantity.</li>
            <li>When it fills, place a <strong>SELL offer at the Sell price</strong>. The GE takes a <strong>2% tax</strong> on the sale — every margin here is already after tax.</li>
            <li>The <strong>margin is your cushion</strong>: if the sell side won't fill and you must lower your price, that's how far you can drop before you start losing. Thin margins (under ~3%) leave almost no room — don't chase.</li>
            <li>Respect the <strong>4-hour buy limit</strong> per item, and check the <strong>est. fill time</strong> — a position that won't fill the same day exposes you to the market moving.</li>
            <li><strong>Start small, and never risk coins you can't afford to lose.</strong> A high safety score means the spread is likely fillable — not that profit is guaranteed.</li>
        </ol>
    </details>

    @{
        var shown = Displayed;
        bool filtered = fMinMargin is not null || fMinSafety is not null || fMinVolume is not null;
        long projProfit = shown.Sum(v => v.ProjectedProfit);
        double avgSafety = shown.Count > 0 ? shown.Average(v => v.Opp.SafetyScore) : 0;
        double bestMargin = shown.Count > 0 ? shown.Max(v => v.Opp.MarginPercent) : 0;
    }

    <section class="stats">
        <div class="stat">
            <span class="tt"><span class="tt-trigger stat-k">Opportunities</span><span class="tt-pop">Picks currently shown after your filters. Each cleared the detection thresholds in Settings.</span></span>
            <span class="stat-v">@shown.Count<span class="stat-sub">@(filtered ? $"of {opportunities.Count}" : "found")</span></span>
        </div>
        <div class="stat">
            <span class="tt"><span class="tt-trigger stat-k">Combined profit if filled</span><span class="tt-pop">Sum of the per-position profit (after 2% tax) across <em>all shown</em> picks, if every leg fills. You may not have the bankroll or time to run them all at once — it's an upper bound.</span></span>
            <span class="stat-v profit">+@Rationale.Gp(projProfit)</span>
        </div>
        <div class="stat">
            <span class="tt"><span class="tt-trigger stat-k">Best margin</span><span class="tt-pop">Highest after-tax cushion among shown picks.</span></span>
            <span class="stat-v">@bestMargin.ToString("F1")%</span>
        </div>
        <div class="stat">
            <span class="tt"><span class="tt-trigger stat-k">Avg safety</span><span class="tt-pop">Mean clean-fill probability across shown picks. Higher = more likely both legs fill.</span></span>
            <span class="stat-v @Rationale.TierClass(avgSafety)">@avgSafety.ToString("F0")</span>
        </div>
    </section>

    <div class="toolbar">
        <a class="link" href="/settings">⚙ Settings &amp; bankroll</a>
        <span class="muted small">@LastUpdatedText · polling /latest every 60s</span>
    </div>

    <div class="filterbar">
        <span class="fb-label">Sort</span>
        <div class="seg-btns">
            <button class="@(sortKey==SortKey.Profit?"on":"")" @onclick="() => SetSort(SortKey.Profit)">Profit@(Arrow(SortKey.Profit))</button>
            <button class="@(sortKey==SortKey.Margin?"on":"")" @onclick="() => SetSort(SortKey.Margin)">Margin@(Arrow(SortKey.Margin))</button>
            <button class="@(sortKey==SortKey.Safety?"on":"")" @onclick="() => SetSort(SortKey.Safety)">Safety@(Arrow(SortKey.Safety))</button>
            <button class="@(sortKey==SortKey.Volume?"on":"")" @onclick="() => SetSort(SortKey.Volume)">Volume@(Arrow(SortKey.Volume))</button>
        </div>
        <span class="fb-sep"></span>
        <span class="fb-label">Min</span>
        <label class="fb-field">margin <input type="number" step="0.5" min="0" placeholder="%" @bind="fMinMargin" @bind:event="oninput" /></label>
        <label class="fb-field">safety <input type="number" step="5" min="0" max="100" placeholder="0-100" @bind="fMinSafety" @bind:event="oninput" /></label>
        <label class="fb-field">volume <input type="number" step="50" min="0" placeholder="/5m" @bind="fMinVolume" @bind:event="oninput" /></label>
        @if (filtered)
        {
            <button class="fb-clear" @onclick="ClearFilters">clear</button>
        }
    </div>

    @if (opportunities.Count == 0 && lastUpdateLocal is null)
    {
        <div class="empty">
            <span class="spin"></span>
            Warming up… the first scan needs one price poll and one 5-minute volume bucket (≈ up to a minute on a cold start).
        </div>
    }
    else if (opportunities.Count == 0)
    {
        <div class="empty empty-none">
            <div>
                <strong>No low-risk opportunities right now.</strong>
                <p class="muted small">This is normal — clean spreads above your 2% cushion on liquid items come and go through the day. Nothing here is safer than waiting. You can loosen the thresholds in <a class="link" href="/settings">Settings</a> (at more risk) or check back shortly.</p>
            </div>
        </div>
    }
    else if (shown.Count == 0)
    {
        <div class="empty empty-none">
            <div>
                <strong>No picks match your filters.</strong>
                <p class="muted small">@opportunities.Count opportunities are available — your sort/filter bar above is hiding them. <button class="fb-clear inline" @onclick="ClearFilters">Clear filters</button></p>
            </div>
        </div>
    }
    else
    {
        <div class="opp-grid">
            <div class="opp-head">
                <span>#</span>
                <span class="tt"><span class="tt-trigger">Item</span><span class="tt-pop">Tradeable item. Icon and buy limit from the OSRS Wiki / RuneLite item data.</span></span>
                <span class="tt"><span class="tt-trigger">Spread</span><span class="tt-pop"><b>Buy</b> = instant-sell price (place a buy offer here). <b>Sell</b> = instant-buy price (place a sell offer here). These are last completed trades, so the live game price may differ.</span></span>
                <span class="th-sort tt @(sortKey==SortKey.Margin?"sorted":"")" @onclick="() => SetSort(SortKey.Margin)"><span class="tt-trigger">Margin / cushion@(Arrow(SortKey.Margin))</span><span class="tt-pop">Net profit per item after the <b>2% GE tax</b>. This is also your <b>cushion</b> — how far the sell price can fall before you break even. Under ~3% leaves little slippage room. We reject under 2% and over 20% (stale data). Click to sort.</span></span>
                <span class="tt"><span class="tt-trigger">Position</span><span class="tt-pop">Suggested buy quantity sized so no single position exceeds ~1/8 of your bankroll (capped by the 4-hour buy limit), the coins required, and an estimate of how long that quantity takes to fill at recent volume.</span></span>
                <span class="th-sort tt @(sortKey==SortKey.Profit?"sorted":"")" @onclick="() => SetSort(SortKey.Profit)"><span class="tt-trigger">Profit if filled@(Arrow(SortKey.Profit))</span><span class="tt-pop"><b>Top</b>: per-position profit if both legs fill (qty × net margin). <b>Below</b>: 4-hour potential, bounded by the buy limit and how much the item actually trades. Click to sort.</span></span>
                <span class="th-sort tt @(sortKey==SortKey.Volume?"sorted":"")" @onclick="() => SetSort(SortKey.Volume)"><span class="tt-trigger">Vol / 5m@(Arrow(SortKey.Volume))</span><span class="tt-pop">Two-sided units traded in the last 5 minutes (the smaller of buy/sell volume) — how much actually changes hands. Higher = easier to fill and exit. Click to sort.</span></span>
                <span class="th-sort tt @(sortKey==SortKey.Safety?"sorted":"")" @onclick="() => SetSort(SortKey.Safety)"><span class="tt-trigger">Safety@(Arrow(SortKey.Safety))</span><span class="tt-pop">Modeled probability of cleanly buying and selling within the window. Hover any meter for the factors behind it. Click to sort.</span></span>
                <span class="tt"><span class="tt-trigger">Age</span><span class="tt-pop">Time since the <b>older</b> of the two prices last traded. Both sides must be fresh (≤ 30 min). Older = trust less.</span></span>
            </div>

            @{ int rank = 0; }
            @foreach (var v in shown)
            {
                var o = v.Opp;
                rank++;
                var factors = Rationale.Factors(o.SafetyBreakdown);
                var marginCls = Rationale.MarginTierClass(o.MarginPercent);
                <div class="opp-row @(v.Affordable ? "" : "overflow")" @key="o.ItemId">
                    <span class="rank">@rank</span>

                    <span class="cell-item">
                        <img class="icon" src="https://static.runelite.net/cache/item/icon/@(o.ItemId).png"
                             alt="" loading="lazy" onerror="this.style.visibility='hidden'" />
                        <span class="item-text">
                            <span class="item-head">
                                <span class="item-name">@o.Name</span>
                                <a class="src-link tt" href="https://prices.runescape.wiki/osrs/item/@o.ItemId" target="_blank" rel="noopener noreferrer">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 3h7v7"/><path d="M21 3l-9 9"/><path d="M21 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5"/></svg>
                                    <span class="tt-pop">Open <b>@o.Name</b> on prices.runescape.wiki — the live price source (history graph &amp; volumes). Opens in a new tab.</span>
                                </a>
                            </span>
                            <span class="tt"><span class="tt-trigger item-sub">limit @o.BuyLimit.ToString("N0") / 4h</span><span class="tt-pop">You can buy at most @o.BuyLimit.ToString("N0") of this item every 4 hours, per account. This caps how much one flip can earn.</span></span>
                        </span>
                    </span>

                    <span class="cell-spread">
                        <span class="buy">@o.BuyPrice.ToString("N0")</span>
                        <span class="arrow">→</span>
                        <span class="sell">@o.SellPrice.ToString("N0")</span>
                    </span>

                    <span class="cell-margin tt">
                        <span class="margin-net @marginCls">+@o.NetMargin.ToString("N0")</span>
                        <span class="margin-pct">@o.MarginPercent.ToString("F1")% @(o.MarginPercent < 3 ? "· thin" : "")</span>
                        <span class="tt-pop">
                            <b>+@o.NetMargin.ToString("N0") gp per item</b> after tax — your cushion is @o.MarginPercent.ToString("F1")%.<br/>
                            Break-even sell price ≈ <b>@Rationale.BreakEvenSell(o.SellPrice, o.NetMargin).ToString("N0")</b>. If the sell side won't fill above that, you lose. @(o.MarginPercent < 3 ? "Thin margin — little room for slippage." : "")
                        </span>
                    </span>

                    <span class="cell-pos">
                        @if (v.Affordable)
                        {
                            <span class="pos-qty">@v.SuggestedQuantity.ToString("N0") units</span>
                            <span class="pos-cap">@Rationale.Gp(v.CapitalNeeded) · <span class="tt"><span class="tt-trigger @(Rationale.FillSlow(v.EstFillHours) ? "fill-slow" : "")">fills @Rationale.FillLabel(v.EstFillHours)</span><span class="tt-pop">Rough time to buy @v.SuggestedQuantity.ToString("N0") units at recent volume (you compete with other buyers, so treat it as a floor).@(Rationale.FillSlow(v.EstFillHours) ? " May not complete the same day — the price can move against you while you wait." : "")</span></span></span>
                        }
                        else
                        {
                            <span class="tt"><span class="tt-trigger pos-na">✕ bankroll too small</span><span class="tt-pop">One unit costs more than the per-position budget (~1/8 of your bankroll). Raise your bankroll or this pick isn't actionable at your size.</span></span>
                        }
                    </span>

                    <span class="cell-profit">
                        <span class="p-proj">+@v.ProjectedProfit.ToString("N0")</span>
                        <span class="p-cycle">4h max @Rationale.Gp(o.ExpectedCycleProfit)</span>
                    </span>

                    <span class="cell-vol">
                        <span class="vol-num">@Rationale.Gp(Math.Min(o.BuyVolume5m, o.SellVolume5m))</span>
                        <span class="vol-sub">units/5m</span>
                    </span>

                    <span class="cell-safety tt">
                        <span class="meter">
                            <span class="meter-bar"><span class="meter-fill @Rationale.TierClass(o.SafetyScore)" style="width:@o.SafetyScore.ToString("F0")%"></span></span>
                            <span class="meter-num">@o.SafetyScore.ToString("F0")</span>
                        </span>
                        <span class="seg">
                            @foreach (var f in factors)
                            {
                                <span class="seg-bit s-@f.Status" style="flex:@f.WeightPct"></span>
                            }
                        </span>

                        <span class="tt-pop card">
                            <span class="card-head">
                                <span class="badge @Rationale.TierClass(o.SafetyScore)">@Rationale.Tier(o.SafetyScore)</span>
                                <span class="card-score">@o.SafetyScore.ToString("F0")<span class="card-score-max">/100</span></span>
                            </span>
                            <span class="card-summary">@Rationale.Summary(o)</span>
                            @foreach (var f in factors)
                            {
                                <span class="factor">
                                    <span class="factor-top">
                                        <span class="factor-label">@f.Label</span>
                                        <span class="factor-meta">@f.Value.ToString("P0") · @f.WeightPct% weight</span>
                                    </span>
                                    <span class="factor-bar"><span class="factor-fill s-@f.Status" style="width:@((f.Value*100).ToString("F0"))%"></span></span>
                                    <span class="factor-why">@f.Explanation</span>
                                </span>
                            }
                            <span class="card-foot">Measures whether you can fill both legs — not whether the margin survives slippage. Check the cushion too.</span>
                        </span>
                    </span>

                    <span class="cell-age">
                        <span class="tt"><span class="tt-trigger age-pill @Rationale.FreshnessClass(o.PriceAgeSeconds)">@Rationale.Age(o.PriceAgeSeconds)</span><span class="tt-pop">Older side last traded @o.PriceAgeSeconds s ago. Both buy and sell prices must be ≤ 30 min old to qualify.</span></span>
                    </span>
                </div>
            }
        </div>
    }

    <footer class="disclaimer">
        Prices are completed-trade aggregates from the OSRS Wiki and can lag the live game, especially for thinly-traded items.
        Margins assume both legs fill at the shown prices after 2% GE tax; real fills may differ. This is an analysis aid, not financial advice — trade at your own risk.
    </footer>
</div>

@code {
    private enum SortKey { Profit, Margin, Safety, Volume }
    private SortKey sortKey = SortKey.Profit;
    private bool sortDesc = true;
    private double? fMinMargin;
    private double? fMinSafety;
    private long? fMinVolume;

    private static long Vol(OpportunityView v) => Math.Min(v.Opp.BuyVolume5m, v.Opp.SellVolume5m);

    private IReadOnlyList<OpportunityView> Displayed
    {
        get
        {
            IEnumerable<OpportunityView> q = opportunities;
            if (fMinMargin is double mm) q = q.Where(v => v.Opp.MarginPercent >= mm);
            if (fMinSafety is double ms) q = q.Where(v => v.Opp.SafetyScore >= ms);
            if (fMinVolume is long mv) q = q.Where(v => Vol(v) >= mv);
            Func<OpportunityView, double> key = sortKey switch
            {
                SortKey.Margin => v => v.Opp.MarginPercent,
                SortKey.Safety => v => v.Opp.SafetyScore,
                SortKey.Volume => v => Vol(v),
                _ => v => v.Opp.RankScore,
            };
            return (sortDesc ? q.OrderByDescending(key) : q.OrderBy(key)).ToList();
        }
    }

    private void SetSort(SortKey k)
    {
        if (sortKey == k) sortDesc = !sortDesc;
        else { sortKey = k; sortDesc = true; }
    }

    private string Arrow(SortKey k) => sortKey != k ? "" : (sortDesc ? " ▾" : " ▴");

    private void ClearFilters() { fMinMargin = null; fMinSafety = null; fMinVolume = null; }

    private HubConnection? _hub;
    private IJSObjectReference? _notifyModule;
    private DashboardSnapshot? snap;
    private IReadOnlyList<OpportunityView> opportunities => snap?.Opportunities ?? Array.Empty<OpportunityView>();
    private string connectionState = "connecting";
    private DateTimeOffset? lastUpdateLocal;
    // Start collapsed so returning visitors never see an open→closed flash; we open it only
    // once we've confirmed (via localStorage) this is a first visit.
    private bool hasSeenHowto = true;

    private PeriodicTimer? _tick;
    private CancellationTokenSource? _tickCts;

    private const double SafetyThreshold = 70;
    private const long ProfitThreshold = 200_000;
    private HashSet<int> _alreadyAlerted = new();

    // "Live" requires: SignalR up, a recent push, and the server reporting a healthy upstream feed.
    private bool IsLive =>
        connectionState == "connected"
        && lastUpdateLocal is { } t && (DateTimeOffset.Now - t).TotalSeconds <= 150
        && snap is { FeedHealthy: true };

    private string FeedStatusText =>
        connectionState != "connected" ? "connection lost — reconnecting…"
        : lastUpdateLocal is null ? "waiting for first data…"
        : snap is { FeedHealthy: false } ? $"upstream feed last responded {snap.FeedAgeSeconds}s ago"
        : (DateTimeOffset.Now - lastUpdateLocal.Value).TotalSeconds > 150 ? "no fresh data received"
        : "feed healthy";

    private string LastUpdatedText =>
        lastUpdateLocal is { } t
            ? $"updated {(int)(DateTimeOffset.Now - t).TotalSeconds}s ago"
            : "not yet updated";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _notifyModule = await JS.InvokeAsync<IJSObjectReference>("import", "./notify.js");
        await _notifyModule.InvokeVoidAsync("requestPermission");
        await _notifyModule.InvokeVoidAsync("initSafetyCards");
        hasSeenHowto = await _notifyModule.InvokeAsync<bool>("seenHowto");

        _hub = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/opportunities"))
            .WithAutomaticReconnect()
            .Build();

        _hub.On<DashboardSnapshot>("OpportunitiesUpdated", async s =>
        {
            snap = s;
            lastUpdateLocal = DateTimeOffset.Now;
            await AlertOnNewHighValue(s.Opportunities);
            await InvokeAsync(StateHasChanged);
        });

        _hub.Reconnecting += _ => { connectionState = "reconnecting"; return InvokeAsync(StateHasChanged); };
        _hub.Reconnected += _ => { connectionState = "connected"; return InvokeAsync(StateHasChanged); };

        await _hub.StartAsync();
        connectionState = "connected";
        snap = await _hub.InvokeAsync<DashboardSnapshot>("GetCurrent");
        if (snap.Opportunities.Count > 0) lastUpdateLocal = DateTimeOffset.Now;
        await InvokeAsync(StateHasChanged);

        // Re-render every 5s so "updated Xs ago" and the stale/live state stay honest
        // even when no push arrives (e.g. the upstream feed dies).
        _tickCts = new CancellationTokenSource();
        _tick = new PeriodicTimer(TimeSpan.FromSeconds(5));
        _ = TickLoop(_tickCts.Token);
    }

    private async Task TickLoop(CancellationToken ct)
    {
        try { while (await _tick!.WaitForNextTickAsync(ct)) await InvokeAsync(StateHasChanged); }
        catch (OperationCanceledException) { }
    }

    private async Task AlertOnNewHighValue(IReadOnlyList<OpportunityView> views)
    {
        if (_notifyModule is null) return;
        foreach (var v in views)
        {
            var o = v.Opp;
            if (v.Affordable && o.SafetyScore >= SafetyThreshold
                && o.ExpectedCycleProfit >= ProfitThreshold
                && _alreadyAlerted.Add(o.ItemId))
            {
                await _notifyModule.InvokeVoidAsync("notify",
                    $"Flip: {o.Name}",
                    $"Profit ~{o.ExpectedCycleProfit:N0} | safety {o.SafetyScore:F0}");
            }
        }
        _alreadyAlerted.IntersectWith(views.Select(v => v.Opp.ItemId));
    }

    public async ValueTask DisposeAsync()
    {
        _tickCts?.Cancel();
        _tick?.Dispose();
        if (_hub is not null) await _hub.DisposeAsync();
        if (_notifyModule is not null)
        {
            try { await _notifyModule.DisposeAsync(); }
            catch (JSDisconnectedException) { /* circuit already gone */ }
        }
    }
}
